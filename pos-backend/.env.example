# Server
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Database (Render PostgreSQL — use Internal URL for same-region services)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=change-me-to-a-strong-random-string

# Redis (Upstash — copy the ioredis URL from your Upstash dashboard)
REDIS_URL=rediss://default:your-password@your-endpoint.upstash.io:6379

# CORS (your Vercel frontend URL, comma-separated for multiple)
CORS_ORIGIN=https://your-app.vercel.app

# Optional: Public API URL (for Swagger docs)
API_URL=https://your-app.onrender.com
