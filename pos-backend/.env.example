# Server
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Database (Local PostgreSQL on VPS)
DATABASE_URL="postgresql://pos_user:your_strong_password@localhost:5432/pos_system?schema=public"

# JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=change-me-to-a-strong-random-string

# Redis (Local Redis on VPS)
REDIS_URL=redis://localhost:6379

# CORS (your frontend URL — use your domain or VPS IP)
CORS_ORIGIN=https://your-domain.com

# Optional: Public API URL (for Swagger docs)
API_URL=https://your-domain.com/api
