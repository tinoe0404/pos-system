# Server
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Database (Neon PostgreSQL — same URL you already use)
DATABASE_URL="postgresql://user:password@hostname/dbname?sslmode=require"

# JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=change-me-to-a-strong-random-string

# Redis (Upstash — same URL you already use)
REDIS_URL=rediss://default:token@hostname:6379

# CORS (your Vercel frontend URL)
CORS_ORIGIN=https://your-app.vercel.app

# Public API URL (your Render backend URL — for Swagger docs)
API_URL=https://your-render-backend-url.onrender.com
