generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  cashier
}

enum SaleStatus {
  PENDING
  COMPLETED
  FAILED
  VOIDED
}

enum PaymentMethod {
  CASH
  ECOCASH
  TAB
}

enum RegisterLogType {
  SALE
  CASH_IN
  CASH_OUT
  ADJUSTMENT
}

enum TabStatus {
  ACTIVE
  CLOSED
  EXHAUSTED
}

enum TabTransactionType {
  DEPOSIT
  PURCHASE
  REFUND
  CASHOUT
}

enum KegStatus {
  NEW
  ACTIVE
  EMPTY
  TAP_RESERVED
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  password_hash String
  pin_hash      String?
  role          UserRole @default(cashier)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  sales          Sale[]
  voided_sales   Sale[]          @relation("VoidedBy")
  refunds        Refund[]
  cash_registers CashRegister[]
  tabs           Tab[]

  @@map("users")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  min_stock   Int      @default(10)
  sku         String   @unique
  category    String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Beer-specific fields
  abv         Decimal? @db.Decimal(4, 1)
  ibu         Int?
  brewery     String?
  style       String?
  is_tap_item Boolean  @default(false)
  unit_volume Decimal? @db.Decimal(10, 2) // in ml, e.g. 500 for a pint

  sale_items   SaleItem[]
  refund_items RefundItem[]
  kegs         Keg[]

  @@map("products")
  @@index([sku])
  @@index([category])
  @@index([stock])
}

model Sale {
  id             String        @id @default(cuid())
  user_id        String
  tab_id         String?
  total          Decimal       @db.Decimal(10, 2)
  status         SaleStatus    @default(PENDING)
  payment_method PaymentMethod @default(CASH)
  void_reason    String?
  voided_by_id   String?
  voided_at      DateTime?
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  user             User              @relation(fields: [user_id], references: [id])
  voided_by        User?             @relation("VoidedBy", fields: [voided_by_id], references: [id])
  tab              Tab?              @relation(fields: [tab_id], references: [id])
  items            SaleItem[]
  refunds          Refund[]
  tab_transactions TabTransaction[]

  @@map("sales")
  @@index([user_id])
  @@index([tab_id])
  @@index([status])
  @@index([created_at])
  @@index([user_id, created_at])   // My sales today queries
  @@index([status, created_at])    // Filtered order lists
}

model SaleItem {
  id            String  @id @default(cuid())
  sale_id       String
  product_id    String
  quantity      Int
  price_at_sale Decimal @db.Decimal(10, 2)
  keg_id        String?

  sale    Sale    @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id])
  keg     Keg?    @relation(fields: [keg_id], references: [id])

  @@map("sale_items")
  @@index([sale_id])
  @@index([product_id])
  @@index([keg_id])
}

enum RefundStatus {
  PENDING
  COMPLETED
  REJECTED
}

model Refund {
  id           String       @id @default(cuid())
  sale_id      String
  user_id      String
  total_amount Decimal      @db.Decimal(10, 2)
  reason       String?
  status       RefundStatus @default(COMPLETED)
  created_at   DateTime     @default(now())

  sale  Sale         @relation(fields: [sale_id], references: [id])
  user  User         @relation(fields: [user_id], references: [id])
  items RefundItem[]

  @@map("refunds")
  @@index([sale_id])
  @@index([user_id])
}

model RefundItem {
  id         String  @id @default(cuid())
  refund_id  String
  product_id String
  quantity   Int
  amount     Decimal @db.Decimal(10, 2)

  refund  Refund  @relation(fields: [refund_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id])

  @@map("refund_items")
}

model CashRegister {
  id              String    @id @default(cuid())
  user_id         String
  opened_at       DateTime  @default(now())
  closed_at       DateTime?
  opening_amount  Decimal   @db.Decimal(10, 2)
  closing_amount  Decimal?  @db.Decimal(10, 2)
  expected_amount Decimal?  @db.Decimal(10, 2)
  notes           String?

  user User              @relation(fields: [user_id], references: [id])
  logs CashRegisterLog[]

  @@map("cash_registers")
  @@index([user_id])
  @@index([opened_at])
}

model CashRegisterLog {
  id          String          @id @default(cuid())
  register_id String
  type        RegisterLogType
  amount      Decimal         @db.Decimal(10, 2)
  note        String?
  created_at  DateTime        @default(now())

  register CashRegister @relation(fields: [register_id], references: [id], onDelete: Cascade)

  @@map("cash_register_logs")
  @@index([register_id])
}

model Tab {
  id              String    @id @default(cuid())
  customer_name   String
  phone           String?
  balance         Decimal   @db.Decimal(10, 2)
  initial_deposit Decimal   @db.Decimal(10, 2)
  status          TabStatus @default(ACTIVE)
  created_by_id   String
  created_at      DateTime  @default(now())
  closed_at       DateTime?

  created_by   User             @relation(fields: [created_by_id], references: [id])
  transactions TabTransaction[]
  sales        Sale[]

  @@map("tabs")
  @@index([status])
  @@index([customer_name])
  @@index([created_by_id])
}

model TabTransaction {
  id         String             @id @default(cuid())
  tab_id     String
  type       TabTransactionType
  amount     Decimal            @db.Decimal(10, 2)
  sale_id    String?
  note       String?
  created_at DateTime           @default(now())

  tab  Tab   @relation(fields: [tab_id], references: [id])
  sale Sale? @relation(fields: [sale_id], references: [id])

  @@map("tab_transactions")
  @@index([tab_id])
}

model Keg {
  id             String    @id @default(cuid())
  product_id     String
  total_volume   Decimal   @db.Decimal(10, 2)
  current_volume Decimal   @db.Decimal(10, 2)
  status         KegStatus @default(NEW)
  tapped_at      DateTime?
  finished_at    DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  product    Product    @relation(fields: [product_id], references: [id])
  sale_items SaleItem[]
  tap        Tap?

  @@map("kegs")
  @@index([product_id])
  @@index([status])
}

model Tap {
  id         Int      @id // Tap number (1, 2, 3...)
  keg_id     String?  @unique
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  keg Keg? @relation(fields: [keg_id], references: [id])

  @@map("taps")
}